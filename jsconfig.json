{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["app/**/*.js", "app/**/*.jsx", "components/**/*.js", "components/**/*.jsx"],
  "exclude": ["node_modules", ".next"]
}
